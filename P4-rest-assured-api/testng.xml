<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Rest Assured API Suite" verbose="1" parallel="classes" thread-count="3">

    <test name="Smoke Tests">
        <groups>
            <run><include name="smoke"/></run>
        </groups>
        <classes>
            <class name="com.tanvir.tests.AuthApiTest"/>
            <class name="com.tanvir.tests.UserApiTest"/>
            <class name="com.tanvir.tests.LoanApiTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run><include name="regression"/></run>
        </groups>
        <classes>
            <class name="com.tanvir.tests.AuthApiTest"/>
            <class name="com.tanvir.tests.UserApiTest"/>
            <class name="com.tanvir.tests.LoanApiTest"/>
        </classes>
    </test>

</suite>
